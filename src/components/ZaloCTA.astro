---
const zaloLink = "https://zalo.me/0343956954";
---

<a 
  href={zaloLink} 
  target="_blank" 
  class="group flex items-center gap-3 bg-white border border-gray-100 px-4 py-3 rounded-full shadow-[0_8px_30px_rgb(0,0,0,0.08)] hover:shadow-[0_8px_30px_rgb(0,168,143,0.15)] hover:-translate-y-1 transition-all duration-300 w-fit ml-auto"
>
  <div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0">
    <img 
      src="/images/zalo.webp" 
      alt="Zalo"
      class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-300"
    />
  </div>
</a>