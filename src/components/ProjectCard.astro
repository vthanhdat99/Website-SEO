---
const { post } = Astro.props;

// Bóc tách an toàn để tránh lỗi API
const title = post?.title?.rendered || 'Đang cập nhật';
const slug = post?.slug || '#';
const excerpt = post?.excerpt?.rendered || post?.content?.rendered || '';
const imageUrl = post?._embedded?.['wp:featuredmedia']?.[0]?.source_url || '';
---

<div class="group flex flex-col xl:flex-row gap-0 w-full items-stretch mb-8 rounded-3xl overflow-hidden bg-white border border-gray-100 shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)] hover:-translate-y-1 transition-all duration-500">
  
  {/* Cột trái: Nội dung (Nền trắng xám nhạt) */}
  <div class="w-full xl:w-5/12 bg-[#F8F9FA] p-8 md:p-12 flex flex-col justify-center relative z-10">
    <h3 class="text-2xl md:text-3xl font-light text-gray-900 mb-4 leading-snug">
      <a 
        href={`/${slug}`} 
        class="hover:text-[#00A88F] transition-colors duration-300"
        set:html={title} 
      />
    </h3>
    
    <div 
      class="text-gray-500 text-sm md:text-base font-light leading-relaxed [&>ul]:list-disc [&>ul]:pl-5 [&>ul>li]:mb-2 [&>p]:mb-4 line-clamp-4" 
      set:html={excerpt}
    />
    
    <div class="mt-6">
      <a href={`/${slug}`} class="inline-flex items-center text-xs font-bold uppercase tracking-widest text-[#00A88F] hover:text-[#008f7a] transition-colors">
        Xem dự án
        <svg class="w-4 h-4 ml-2 group-hover:translate-x-2 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>
  </div>

  {/* Cột phải: Hình ảnh */}
  <div class="w-full xl:w-7/12 relative overflow-hidden min-h-[300px] md:min-h-[400px]">
    {imageUrl ? (
      <img 
        src={imageUrl} 
        alt={title}
        loading="lazy"
        class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
      />
    ) : (
      <div class="absolute inset-0 w-full h-full bg-gray-100 flex items-center justify-center">
         <span class="text-gray-300 font-bold text-2xl tracking-widest uppercase">PROJECT</span>
      </div>
    )}
  </div>
  
</div>