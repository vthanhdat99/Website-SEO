---
const { post } = Astro.props;
---

<div class="group flex flex-col xl:flex-row gap-4 md:gap-6 w-full items-stretch mb-8">
  
  <div class="w-full xl:w-5/12 bg-[#0d3552]/80 text-white p-6 md:p-8 rounded-[20px] flex flex-col justify-center shadow-md">
    
    <h3 class="text-2xl md:text-3xl font-medium mb-2">
      <a 
        href={`/${post.slug}`} 
        class="hover:text-[#8B7355] transition-colors duration-300"
        set:html={post.title.rendered} 
      />
    </h3>
    
    <div 
      class="text-gray-100 text-sm md:text-base [&>ul]:list-disc [&>ul]:pl-5 [&>ul>li]:mb-2 [&>p]:mb-2 line-clamp-6" 
      set:html={post.content.rendered}
    />
  </div>

  <div class="w-full xl:w-7/12 relative overflow-hidden rounded-[20px] shadow-md min-h-[250px] md:min-h-[320px]">
    {post._embedded && post._embedded['wp:featuredmedia'] ? (
      <img 
        src={post._embedded['wp:featuredmedia'][0].source_url} 
        alt={post.title.rendered}
        loading="lazy"
        class="absolute inset-0 w-full h-full object-cover opacity-80"
      />
    ) : (
      <div class="absolute inset-0 w-full h-full bg-gray-200 flex items-center justify-center">
         <span class="text-gray-400 font-serif font-bold text-xl tracking-widest">PROJECT</span>
      </div>
    )}
  </div>
  
</div>