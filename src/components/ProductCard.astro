---
// Nhận vào prop là 'product' thay vì 'post' để đồng bộ với API mới
const { product } = Astro.props;

// TRÍCH XUẤT DỮ LIỆU AN TOÀN TỪ CUSTOM POST TYPE 'PRODUCT'
// Dùng optional chaining (?.) kế thừa chính xác từ logic trang chi tiết
const title = product?.title?.rendered || 'Sản phẩm đang cập nhật';
const slug = product?.slug || '#';
const imageUrl = product?._embedded?.['wp:featuredmedia']?.[0]?.source_url || '';

// Lấy giá tiền từ ACF của CPT Product
const giaTien = product?.acf?.gia_tien || '';
---

{/* Đường dẫn URL động theo slug của Product */}
<a href={`/san-pham/${slug}`} class="group flex flex-col h-full bg-white rounded-2xl border border-gray-100 overflow-hidden hover:shadow-[0_8px_30px_rgb(0,0,0,0.08)] hover:-translate-y-1 transition-all duration-500">
  
  {/* KHỐI HÌNH ẢNH */}
  <div class="relative bg-[#F8F9FA] aspect-[4/5] flex items-center justify-center p-8 overflow-hidden shrink-0">
    <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors duration-500 z-10"></div>
    
    {imageUrl ? (
      <img 
        src={imageUrl} 
        alt={title}
        loading="lazy"
        class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-700 ease-out mix-blend-multiply drop-shadow-md relative z-0"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center">
         <span class="text-gray-300 font-bold text-2xl tracking-widest uppercase">REXAM</span>
      </div>
    )}
  </div>
  
  {/* KHỐI NỘI DUNG */}
  <div class="p-6 flex flex-col flex-grow bg-white z-20">
    <h3 class="text-lg font-medium text-gray-800 mb-2 group-hover:text-[#00A88F] transition-colors line-clamp-2 leading-snug" set:html={title} />
    
    {/* Hiển thị Giá tiền (Nếu có) */}
    {giaTien && (
       <div class="text-[#00A88F] font-semibold text-sm mb-4">{giaTien}</div>
    )}
    
    {/* Nút Xem chi tiết đẩy xuống đáy thẻ */}
    <div class="mt-auto pt-4 border-t border-gray-50 flex items-center justify-between">
      <span class="text-[13px] font-bold text-gray-400 uppercase tracking-wider group-hover:text-[#00A88F] transition-colors">
        Xem chi tiết
      </span>
      
      <div class="w-8 h-8 rounded-full bg-gray-50 flex items-center justify-center text-gray-400 group-hover:bg-[#00A88F] group-hover:text-white transition-all duration-300 group-hover:translate-x-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      </div>
    </div>
  </div>
</a>