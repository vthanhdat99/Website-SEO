---
import MainLayout from "../layouts/MainLayout.astro"
import ContactForm from "../components/ContactForm.astro"
import ServiceCard from "../components/ServiceCard.astro"
import ProductCard from "../components/ProductCard.astro"
import ProjectCard from "../components/ProjectCard.astro"
import { fetchWP } from "../utils/fetchWP";

const dichVuID = 3;
const sanPhamID = 4;
const duAnID = 7; 

const urlDichVu = `https://dev-rexam-backend.pantheonsite.io/wp-json/wp/v2/posts?_embed&categories=${dichVuID}&per_page=6`;
const urlSanPham = `https://dev-rexam-backend.pantheonsite.io/wp-json/wp/v2/posts?_embed&categories=${sanPhamID}&per_page=6`;
const urlDuAn = `https://dev-rexam-backend.pantheonsite.io/wp-json/wp/v2/posts?_embed&categories=${duAnID}&per_page=6`; 

const [postsDichVu, postsSanPham, postsDuAn] = await Promise.all([
  fetchWP<any[]>(urlDichVu),
  fetchWP<any[]>(urlSanPham),
  fetchWP<any[]>(urlDuAn) 
]);
---

<MainLayout
  title="Thi công sơn epoxy & chống cháy | Chuyên nghiệp"
  description="Dịch vụ thi công sơn epoxy, sơn chống cháy nhà xưởng tại HCM. Báo giá nhanh chóng."
>
  <section class="relative min-h-[85vh] flex items-center bg-gray-900 bg-[url('/images/hero-bg.jpg')] bg-cover bg-center bg-no-repeat">
    <div class="absolute inset-0 bg-gradient-to-r from-[#2C4032] via-[#2C4032]/85 to-transparent"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-12 w-full">
      <div class="max-w-2xl">
        <p class="text-gray-300 text-sm md:text-base uppercase tracking-widest mb-4 font-medium flex items-center gap-2">
          <span class="w-8 h-[1px] bg-[#8B7355]"></span> Giải Pháp Sơn Công Nghiệp
        </p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif text-[#EFE7D3] font-normal leading-tight mb-6">
          Thi Công Sơn Epoxy HCM <br/>
        </h1>
        <p class="text-gray-300 text-base md:text-lg mb-10 max-w-xl leading-relaxed">
          Bề Mặt Hoàn Hảo Cho Nhà Xưởng Của Bạn, Chỉ Cách Một Cú Nhấp Chuột: Tìm Sự Bền Bỉ Cho Công Trình Của Bạn Tại Khu Vực Miền Nam.
        </p>
        
        <div class="flex flex-col lg:flex-row items-start lg:items-center gap-6 lg:gap-8 mt-8">
          <div class="flex flex-col sm:flex-row w-full lg:w-auto gap-4">
            <a href="#dich-vu" class="w-full sm:w-auto inline-flex justify-center items-center px-8 py-3.5 bg-[#527052] hover:bg-[#435c43] text-white text-sm font-medium tracking-wide rounded-full transition-colors duration-300">
              TÌM HIỂU THÊM
            </a>
            <a href="#form-tu-van" class="w-full sm:w-auto inline-flex justify-center items-center px-8 py-3.5 bg-[#4B3B2B] hover:bg-[#3a2d21] text-[#EFE7D3] text-sm font-medium tracking-wide rounded-full transition-colors duration-300 border border-[#8B7355]/30 shadow-lg">
              NHẬN BÁO GIÁ
            </a>
          </div>

          <div class="flex items-center gap-4 pt-2 sm:pt-0">
            <a href="https://www.youtube.com/watch?v=LINK_YOUTUBE_CUA_BAN" target="_blank" class="relative group flex items-center justify-center w-14 h-14 bg-[#8B7355] hover:bg-[#7A6447] rounded-full transition-transform duration-300 hover:scale-105 cursor-pointer shrink-0 shadow-lg border-2 border-[#EFE7D3]/20">
              <span class="absolute inset-0 rounded-full bg-[#8B7355] animate-ping opacity-40 group-hover:opacity-60"></span>
              <svg class="w-6 h-6 text-[#EFE7D3] ml-1 z-10" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            </a>
            <span class="text-[#EFE7D3] text-sm font-medium tracking-wide leading-relaxed">Xem Video <br class="hidden sm:block"> Thực Tế</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="du-an" class="bg-[#2C4032]/90 py-20 px-6 lg:px-12">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-serif text-[#EFE7D3] mb-4">Dự Án Tiêu Biểu</h2>
        <div class="w-24 h-1 bg-[#8B7355] mx-auto"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {postsDuAn.map((post: any) => (
          <ProjectCard post={post} />
        ))}
      </div>
      
      <div class="text-center mt-12">
        <a href="#form-tu-van" class="inline-flex items-center gap-2 text-[#EFE7D3] border border-[#8B7355] px-8 py-3 rounded-full hover:bg-[#8B7355] transition-colors duration-300">
          Đăng ký khảo sát công trình
        </a>
      </div>
    </div>
  </section>

  <section id="dich-vu" class="bg-[#F4F1EA] py-20 px-6 lg:px-12">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-serif text-[#2C4032] mb-4">Các Dịch Vụ Cốt Lõi</h2>
        <div class="w-24 h-1 bg-[#8B7355] mx-auto"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {postsDichVu.map((post: any) => (
          <ServiceCard post={post} />
        ))}
      </div>
    </div>
  </section>

  <section id="san-pham" class="bg-white py-20 px-6 lg:px-12">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-serif text-[#2C4032] mb-4">Sản Phẩm Của Chúng Tôi</h2>
        <div class="w-24 h-1 bg-[#8B7355] mx-auto"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {postsSanPham.map((post: any) => (
          <ProductCard post={post} />
        ))}
      </div>
    </div>
  </section>

  <ContactForm />
</MainLayout>