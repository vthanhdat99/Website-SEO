---
import MainLayout from "../layouts/MainLayout.astro"
import ContactForm from "../components/ContactForm.astro"
import ServiceCard from "../components/ServiceCard.astro"
import ProductCard from "../components/ProductCard.astro"
import ProjectCard from "../components/ProjectCard.astro"
import { fetchWP } from "../utils/fetchWP";

// Vẫn giữ Category ID cho Dịch vụ và Dự án (Vì bạn chỉ mới chuyển Sản phẩm thành CPT)
const dichVuID = 3;
const duAnID = 7; 

// CHỈNH LẠI LOGIC API: 
// 1. Sản phẩm: Gọi thẳng vào endpoint CPT /product (Lấy 8 bài để chia 4 cột đẹp mắt)
// 2. Dịch vụ & Dự án: Lấy 3 bài tiêu biểu nhất để chia 3 cột
const urlSanPham = `https://dev-rexam-backend.pantheonsite.io/wp-json/wp/v2/product?_embed&per_page=8`;
const urlDichVu = `https://dev-rexam-backend.pantheonsite.io/wp-json/wp/v2/posts?_embed&categories=${dichVuID}&per_page=3`;
const urlDuAn = `https://dev-rexam-backend.pantheonsite.io/wp-json/wp/v2/posts?_embed&categories=${duAnID}&per_page=3`; 

const [postsDichVu, products, postsDuAn] = await Promise.all([
  fetchWP<any[]>(urlDichVu),
  fetchWP<any[]>(urlSanPham),
  fetchWP<any[]>(urlDuAn) 
]);
---

<MainLayout
  title="Trang chủ | Giải pháp sơn công nghiệp chuyên nghiệp REXAM"
  description="Dịch vụ thi công sơn epoxy, sơn chống cháy nhà xưởng tại HCM. Cung cấp sản phẩm chất lượng cao."
>
  {/* ================= HERO BANNER ================= */}
  <section class="relative min-h-[85vh] flex items-center bg-gray-900 bg-[url('/images/hero-bg.jpg')] bg-cover bg-center bg-no-repeat">
    {/* Lớp phủ đen/xám hiện đại, bỏ màu xanh rêu cũ */}
    <div class="absolute inset-0 bg-gradient-to-r from-gray-900/90 via-gray-900/70 to-transparent"></div>
    
    <div class="relative z-10 max-w-[1300px] mx-auto px-6 lg:px-12 w-full">
      <div class="max-w-2xl">
        <p class="text-[#00A88F] text-xs md:text-sm uppercase tracking-[0.2em] mb-6 font-bold flex items-center gap-3">
          <span class="w-10 h-[2px] bg-[#00A88F]"></span> Giải Pháp Sơn Công Nghiệp
        </p>
        <h1 class="text-4xl md:text-5xl lg:text-[4rem] text-white font-light leading-[1.1] mb-6 tracking-wide">
          Bề Mặt Hoàn Hảo <br/> Cho Nhà Xưởng
        </h1>
        <p class="text-gray-300 text-base md:text-lg mb-10 max-w-xl leading-relaxed font-light">
          Tìm kiếm sự bền bỉ cho công trình của bạn với các giải pháp sơn Epoxy và sơn công nghiệp hàng đầu tại Việt Nam.
        </p>
        
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-5 mt-8">
          <a href="#san-pham" class="w-full sm:w-auto inline-flex justify-center items-center px-8 py-3.5 bg-[#00A88F] hover:bg-[#008f7a] text-white text-sm font-bold tracking-wider rounded-full transition-all duration-300 shadow-[0_4px_15px_rgba(0,168,143,0.3)] hover:-translate-y-0.5">
            KHÁM PHÁ SẢN PHẨM
          </a>
          <a href="#form-tu-van" class="w-full sm:w-auto inline-flex justify-center items-center px-8 py-3.5 bg-transparent border border-white/30 hover:bg-white hover:text-gray-900 text-white text-sm font-bold tracking-wider rounded-full transition-all duration-300">
            NHẬN BÁO GIÁ
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* ================= SECTION SẢN PHẨM NỔI BẬT ================= */}
  <section id="san-pham" class="scroll-mt-12 bg-white py-20 lg:py-28 px-4 md:px-8 lg:px-12">
    <div class="max-w-[1300px] mx-auto">
      
      <div class="text-center mb-16">
        <h2 class="text-xs font-bold text-[#00A88F] uppercase tracking-widest mb-3">REXAM Collection</h2>
        <h3 class="text-3xl md:text-[2.5rem] font-light text-gray-800 tracking-wide">Sản Phẩm Tiêu Biểu</h3>
        <p class="text-gray-500 mt-4 font-light max-w-2xl mx-auto">Các dòng sơn chất lượng cao được tin dùng bởi nhà thầu và kỹ sư.</p>
      </div>

      {/* Dùng Grid 4 cột cho thẻ sản phẩm */}
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        {Array.isArray(products) && products.map((product: any) => (
          /* TRUYỀN BIẾN product VÀO PRODUCT CARD */
          <ProductCard product={product} />
        ))}
      </div>
      
      <div class="text-center mt-12">
        <a href="/san-pham" class="inline-block border border-gray-200 text-gray-600 hover:text-[#00A88F] hover:border-[#00A88F] px-8 py-3 rounded-full text-sm font-bold uppercase tracking-wider transition-all duration-300">
          Xem toàn bộ danh mục
        </a>
      </div>
    </div>
  </section>

  {/* ================= SECTION DỊCH VỤ ================= */}
  {/* Chuyển sang nền xám nhạt để phân tách không gian */}
  <section id="dich-vu" class="scroll-mt-12 bg-[#F8F9FA] py-20 lg:py-28 px-4 md:px-8 lg:px-12">
    <div class="max-w-[1300px] mx-auto">
      
      <div class="text-center mb-16">
        <h2 class="text-xs font-bold text-[#00A88F] uppercase tracking-widest mb-3">Chuyên Môn Của Rexam</h2>
        <h3 class="text-3xl md:text-[2.5rem] font-light text-gray-800 tracking-wide">Dịch Vụ Cốt Lõi</h3>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {Array.isArray(postsDichVu) && postsDichVu.map((post: any) => (
          <ServiceCard post={post} />
        ))}
      </div>
      
    </div>
  </section>

  {/* ================= SECTION DỰ ÁN ================= */}
  <section id="du-an" class="scroll-mt-12 bg-white py-20 lg:py-28 px-4 md:px-8 lg:px-12">
    <div class="max-w-[1300px] mx-auto">

      <div class="text-center mb-16">
        <h2 class="text-xs font-bold text-[#00A88F] uppercase tracking-widest mb-3">Công trình thực tế</h2>
        <h3 class="text-3xl md:text-[2.5rem] font-light text-gray-800 tracking-wide">Dự Án Tiêu Biểu</h3>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {Array.isArray(postsDuAn) && postsDuAn.map((post: any) => (
          <ProjectCard post={post} />
        ))}
      </div>

      <div class="text-center mt-16">
        <a 
          href="#form-tu-van" 
          class="inline-flex items-center gap-2 bg-[#00A88F] text-white px-10 py-3.5 rounded-full font-bold uppercase tracking-wider hover:bg-[#008f7a] shadow-lg transition-all duration-300 hover:-translate-y-1"
        >
          Đăng ký khảo sát công trình
        </a>
      </div>

    </div>
  </section>

  {/* ================= FORM LIÊN HỆ ================= */}
  <ContactForm />
</MainLayout>