---
import MainLayout from "../../layouts/MainLayout.astro";

// 1. Tạo các đường dẫn tĩnh cho tất cả sản phẩm
export async function getStaticPaths() {
  const wpUrl = "https://dev-rexam-backend.pantheonsite.io/wp-json/wp/v2/product?_embed&per_page=100";
  const res = await fetch(wpUrl);
  const products = await res.json();

  if (!Array.isArray(products)) {
    return [];
  }

  return products.map((product: any) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;

// 2. Trích xuất dữ liệu an toàn
const title = product?.title?.rendered || 'Sản phẩm REXAM';
const excerpt = product?.excerpt?.rendered || '';
const imageUrl = product?._embedded?.['wp:featuredmedia']?.[0]?.source_url || '';

const giaTien = product?.acf?.gia_tien || 'Liên hệ báo giá';
const huongDan = product?.acf?.thong_tin_chi_tiet || '';
const quyCach = product?.acf?.quy_cach || 'Đang cập nhật';
const khuyenMai = product?.acf?.khuyen_mai || '';

// 3. TỰ ĐỘNG BÓC TÁCH TAG & MÔ TẢ TAG
let productFeatures: any[] = [];
if (product?._embedded?.['wp:term']) {
  const terms = product._embedded['wp:term'].flat();
  productFeatures = terms.map((t: any) => ({
    name: t.name,
    description: t.description || '' // Lấy mô tả nếu bạn có nhập trong WordPress
  }));
}

// 4. Tối ưu dữ liệu SEO
const descriptionSEO = excerpt.replace(/(<([^>]+)>)/gi, "") || "Chi tiết sản phẩm sơn công nghiệp REXAM.";
const numericPrice = giaTien.replace(/\D/g, '') || "0";
---

<MainLayout 
  title={`${title} | Tìm sản phẩm cho dự án của bạn | REXAM`} 
  description={descriptionSEO}
>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;500;600;700&display=swap');
    .font-quicksand { font-family: 'Quicksand', sans-serif; }
  </style>

  <div class="bg-white min-h-screen py-10 px-4 md:px-8 lg:px-12 font-quicksand">
    <div class="max-w-[1300px] mx-auto">
      
      {/* THANH ĐIỀU HƯỚNG */}
      <nav class="text-sm text-gray-500 mb-8 flex items-center gap-2 font-medium">
        <a href="/" class="hover:text-[#00A88F] transition-colors">Trang chủ</a> 
        <span>/</span>
        <a href="/san-pham" class="hover:text-[#00A88F] transition-colors">Sản phẩm</a> 
        <span>/</span>
        <span class="text-gray-800" set:html={title}></span>
      </nav>
      
      {/* KHỐI TỔNG QUAN SẢN PHẨM */}
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 mb-20">
        
        {/* CỘT TRÁI: HÌNH ẢNH */}
        <div class="w-full lg:w-[40%] flex-shrink-0">
          <div class="sticky top-24 relative bg-[#F8F9FA] aspect-square flex items-center justify-center p-12 lg:p-16 overflow-hidden rounded-2xl border border-gray-100">
            
            {/* KHỐI BADGE KHUYẾN MÃI NỔI */}
            {khuyenMai && (
              <div class="absolute top-4 left-4 lg:top-6 lg:left-6 z-20 max-w-[80%]">
                <div class="bg-gradient-to-r from-[#00A88F] to-[#008f7a] text-white pl-3 pr-4 py-2 rounded-full shadow-[0_8px_15px_rgba(0,168,143,0.25)] flex items-start gap-2 border border-[#00A88F]/20 backdrop-blur-sm">
                  <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"></path>
                  </svg>
                  {/* Dùng line-clamp-2 để lỡ nội dung khuyến mãi dài thì tự động có dấu ... không bị vỡ Layout */}
                  <span class="text-xs md:text-sm font-medium tracking-wide line-clamp-2" set:html={khuyenMai}></span>
                </div>
              </div>
            )}

            {/* ẢNH SẢN PHẨM */}
            {imageUrl ? (
              <img
                src={imageUrl}
                alt={title}
                class="w-full h-full object-contain hover:scale-110 transition-transform duration-700 ease-out mix-blend-multiply drop-shadow-xl relative z-10"
              />
            ) : (
              <span class="text-gray-300 text-3xl font-bold tracking-widest uppercase relative z-10">REXAM</span>
            )}
          </div>
        </div>

        {/* CỘT PHẢI: THÔNG TIN (Mở rộng lên 60%) */}
        <div class="w-full lg:w-[60%] flex flex-col justify-start pt-2">
          
          <h1 class="text-3xl md:text-4xl lg:text-[2.5rem] font-light text-gray-800 mb-6 leading-tight tracking-wide" set:html={title}></h1>
          
          {/* Giá tiền và Quy cách */}
          <div class="mb-8 border-b border-gray-100 pb-8 flex flex-col sm:flex-row sm:items-end gap-6 justify-between">
             <div>
               <div class="text-[2rem] font-medium text-[#2C4032] leading-none mb-2">{giaTien}</div>
               <div class="text-gray-500 text-sm flex items-center gap-2">
                  <svg class="w-4 h-4 text-[#00A88F]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
                  Quy cách đóng gói: <strong class="text-gray-700 font-medium">{quyCach}</strong>
               </div>
             </div>
             
             {/* Nhóm Nút Bấm Tối Giản */}
             <div class="flex gap-3 shrink-0">
               <a href="tel:0343956954" class="bg-gray-50 border border-gray-200 text-gray-700 hover:bg-gray-100 px-6 py-3 rounded-full font-bold transition-colors flex items-center gap-2 text-sm">
                 Gọi tư vấn
               </a>
               <a href="https://zalo.me/0343956954" target="_blank" class="bg-[#00A88F] hover:bg-[#008f7a] text-white px-8 py-3 rounded-full font-bold transition-all shadow-[0_4px_15px_rgba(0,168,143,0.3)] hover:-translate-y-0.5 flex items-center gap-2 text-sm">
                 Nhận báo giá
               </a>
             </div>
          </div>

          {/* NHÓM TÍNH NĂNG NỔI BẬT (TAGS + MÔ TẢ) */}
          {productFeatures.length > 0 && (
            <div class="mb-10">
              <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-6">Nổi bật</h3>
              
              {/* Lưới tính năng: 2 cột trên Desktop, 1 cột trên Mobile */}
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {productFeatures.map(feat => feat.description?.trim() && (
                  <div class="flex items-start gap-4 p-5 rounded-2xl bg-[#F8F9FA] border border-transparent hover:border-[#00A88F]/30 hover:bg-white hover:shadow-lg transition-all duration-300 group">
                    <div class="bg-white p-2 rounded-full shadow-sm shrink-0 mt-0.5 text-[#00A88F] group-hover:bg-[#00A88F] group-hover:text-white transition-colors">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
                    </div>
                    <div class="flex items-center min-h-[40px]">
                      {feat.description ? (
                        <span class="text-gray-500 text-xs leading-relaxed line-clamp-3 block">{feat.description}</span>
                      ) : (
                        <span class="text-gray-400 text-xs italic">Đang cập nhật mô tả...</span>
                      )}
                    </div>
                  </div>
                ))}
              </div>
              
            </div>
          )}
          
          {/* Đoạn tóm tắt */}
          {excerpt && (
            <div class="prose prose-gray max-w-none text-gray-600 font-light leading-relaxed text-base pt-6 border-t border-gray-100" set:html={excerpt}></div>
          )}

        </div>
      </div>

      {/* KHỐI NỘI DUNG CHI TIẾT */}
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-20">
        
        <div class="lg:col-span-2 space-y-16">
          {huongDan && (
            <section>
              <h2 class="text-2xl font-bold text-gray-800 mb-8 border-b pb-4">Chi tiết sản phẩm</h2>
              <div class="prose prose-lg max-w-none text-gray-600 font-light leading-relaxed" set:html={huongDan}></div>
            </section>
          )}
        </div>

        <!-- Banner Cam Kết -->
        <div class="lg:col-span-1">
          <div class="bg-gray-50 border border-gray-200 text-gray-800 p-8 rounded-2xl sticky top-24">
            <h3 class="text-xl font-bold mb-6 flex items-center gap-2">
              <svg 
                class="w-6 h-6 text-[#00A88F]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              Chúng tôi luôn sẵn sàng
            </h3>

            <ul class="space-y-4 text-sm text-gray-700">
              <li class="flex items-start gap-3">
                <span class="text-[#00A88F] font-bold">✓</span>
                <span><strong>100% sơn chính hãng</strong>, nguồn gốc xuất xứ rõ ràng từ các thương hiệu uy tín.</span>
              </li>

              <li class="flex items-start gap-3">
                <span class="text-[#00A88F] font-bold">✓</span>
                <span><strong>Cung cấp đầy đủ CO/CQ</strong>, hóa đơn và chứng từ theo yêu cầu.</span>
              </li>

              <li class="flex items-start gap-3">
                <span class="text-[#00A88F] font-bold">✓</span>
                <span><strong>Tư vấn & hỗ trợ kỹ thuật 24/7</strong>, hướng dẫn lựa chọn sản phẩm và quy trình thi công phù hợp.</span>
              </li>

              <li class="flex items-start gap-3">
                <span class="text-[#00A88F] font-bold">✓</span>
                <span><strong>Giao hàng toàn quốc</strong>, nhanh chóng và đúng tiến độ công trình.</span>
              </li>

              <li class="flex items-start gap-3">
                <span class="text-[#00A88F] font-bold">✓</span>
                <span><strong>Đổi mới 1:1</strong> đối với sản phẩm lỗi do nhà sản xuất.</span>
              </li>
            </ul>

            <div class="mt-6 pt-6 border-t border-gray-200">
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org/",
    "@type": "Product",
    "name": title,
    "image": imageUrl ? [imageUrl] : [],
    "description": descriptionSEO,
    "brand": {
      "@type": "Brand",
      "name": "REXAM"
    },
    "offers": {
      "@type": "Offer",
      "url": `https://rexam.vn/san-pham/${product.slug}`,
      "priceCurrency": "VND",
      "price": numericPrice,
      "availability": "https://schema.org/InStock",
      "itemCondition": "https://schema.org/NewCondition"
    }
  })} />
</MainLayout>