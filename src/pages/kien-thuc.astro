---
import MainLayout from "../layouts/MainLayout.astro"

const categoryId = 6; 

// 1. Fetch bài viết từ WP, lấy 12 bài mới nhất của danh mục này
const wpUrl = `https://dev-rexam-backend.pantheonsite.io/wp-json/wp/v2/posts?_embed&categories=${categoryId}&per_page=12`;
const res = await fetch(wpUrl);
const posts = await res.json();

const safePosts = Array.isArray(posts) ? posts : [];
---

<MainLayout
  title="Kiến thức chuyên ngành | Thi Công Sơn Epoxy HCM"
  description="Tổng hợp các kiến thức, kinh nghiệm và cẩm nang về thi công sơn epoxy, sơn chống cháy."
>
  {/* ================= HEADER TRANG KIẾN THỨC (Màu xám nhạt nhẹ nhàng, thanh lịch) ================= */}
  <section class="bg-[#F8F9FA] py-20 lg:py-28 px-6 border-b border-gray-100">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-[#00A88F] text-xs uppercase tracking-[0.2em] mb-4 font-bold">Cẩm nang Rexam</p>
      <h1 class="text-4xl md:text-5xl font-light text-gray-800 mb-6 tracking-wide">Kiến Thức & Kinh Nghiệm</h1>
      <p class="text-gray-500 max-w-2xl mx-auto text-base md:text-lg font-light leading-relaxed">
        Chia sẻ kinh nghiệm thực tế, giải pháp kỹ thuật thi công và cẩm nang bảo dưỡng sàn nhà xưởng bền đẹp theo tiêu chuẩn công nghiệp.
      </p>
    </div>
  </section>

  {/* ================= DANH SÁCH BÀI VIẾT ================= */}
  <section class="bg-white py-16 md:py-24 px-4 md:px-8 lg:px-12 min-h-screen">
    <div class="max-w-[1300px] mx-auto">
      
      {safePosts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {safePosts.map((post: any) => {
            // 2. TRÍCH XUẤT DỮ LIỆU AN TOÀN TRÁNH CRASH 
            const title = post?.title?.rendered || 'Đang cập nhật';
            const slug = post?.slug || '#';
            const excerpt = post?.excerpt?.rendered || '';
            const imageUrl = post?._embedded?.['wp:featuredmedia']?.[0]?.source_url || '';

            return (
              <a href={`/${slug}`} class="group flex flex-col h-full bg-white rounded-3xl border border-gray-100 overflow-hidden shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:shadow-[0_8px_30px_rgb(0,0,0,0.1)] hover:-translate-y-1 transition-all duration-500">
                
                {/* KHỐI ẢNH ĐẠI DIỆN BÀI VIẾT */}
                <div class="h-56 bg-[#F8F9FA] overflow-hidden relative shrink-0">
                  <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors duration-500 z-10"></div>
                  {imageUrl ? (
                    <img 
                      src={imageUrl} 
                      alt={title}
                      loading="lazy"
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center">
                       <span class="text-gray-300 font-bold text-2xl tracking-widest uppercase">REXAM</span>
                    </div>
                  )}
                </div>
                
                {/* KHỐI NỘI DUNG TÓM TẮT */}
                <div class="p-8 flex flex-col flex-grow bg-white">
                  <h3 class="text-xl font-medium text-gray-900 mb-4 group-hover:text-[#00A88F] transition-colors leading-snug line-clamp-2" set:html={title} />
                  
                  <div class="text-gray-500 font-light text-sm leading-relaxed line-clamp-3 mb-6 flex-grow" set:html={excerpt} />
                  
                  <div class="flex items-center text-xs font-bold text-[#00A88F] uppercase tracking-widest mt-auto pt-6 border-t border-gray-50">
                    Đọc bài viết
                    <svg class="w-4 h-4 ml-2 group-hover:translate-x-2 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        /* TRẠNG THÁI TRỐNG (EMPTY STATE) */
        <div class="text-center py-24 text-gray-500">
          <p class="text-lg font-light mb-6">Hiện tại chưa có bài viết kiến thức nào được đăng tải.</p>
          <a href="/" class="inline-block border border-gray-100 text-gray-600 hover:text-[#00A88F] hover:border-[#00A88F] px-8 py-3 rounded-full text-sm font-bold uppercase tracking-wider transition-all duration-300">
            ← Quay lại trang chủ
          </a>
        </div>
      )}

    </div>
  </section>
</MainLayout>