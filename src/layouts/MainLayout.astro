---
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"
import ZaloCTA from "../components/ZaloCTA.astro"
import PhoneCTA from "../components/PhoneCTA.astro"
import FormCTA from "../components/FormCTA.astro"

import SEO from "../components/SEO.astro"
// QUAN TRỌNG: Phải import file CSS này để Tailwind hoạt động
import "../styles/global.css"

const { title, description } = Astro.props
---

<html lang="vi" class="scroll-smooth">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <meta name="google-site-verification" content="_-aYWFRRwqcxSadz40NFXY8PTxeTLBbZ6tKUDUd0XfY" />
    
    <SEO title={title} description={description} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  </head>

  <body class="font-['Quicksand',sans-serif] bg-white text-gray-800 antialiased flex flex-col min-h-screen">
    
    <Header />

    <main class="flex-grow">
      <slot />
    </main>

    <Footer />
    
    <div class="fixed bottom-6 right-6 z-40 flex flex-col items-end gap-4">
      <FormCTA />
      <ZaloCTA />
      <PhoneCTA />
    </div>
    
  </body>
</html>

<style is:global>
  /* Định dạng chuẩn cho các khối nội dung lấy từ WordPress API (Trang sản phẩm, Bài viết...) */
  .dulux-content h1, 
  .dulux-content h2, 
  .dulux-content h3 {
    font-weight: 300; 
    color: #1f2937; 
    margin-top: 2.5rem;
    margin-bottom: 1.5rem;
    line-height: 1.3;
  }
  
  .dulux-content h2 { font-size: 2.25rem; } 
  .dulux-content h3 { font-size: 1.75rem; }
  
  .dulux-content p {
    color: #4b5563;
    line-height: 1.8; 
    margin-bottom: 1.25rem;
    font-weight: 400;
  }

  /* Định dạng danh sách chuẩn chỉ, thay thế dấu chấm mặc định bằng bullet màu xám tinh tế */
  .dulux-content ul {
    margin-bottom: 1.5rem;
    padding-left: 0;
  }
  
  .dulux-content li {
    color: #4b5563;
    line-height: 1.8;
    margin-bottom: 0.5rem;
    position: relative;
    padding-left: 1.5rem;
  }
  
  .dulux-content li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.75rem;
    width: 6px;
    height: 6px;
    background-color: #9ca3af;
    border-radius: 50%;
  }
  
  .dulux-content strong, 
  .dulux-content b {
    font-weight: 600;
    color: #1f2937;
  }

  /* Tùy chỉnh thêm thanh cuộn (Scrollbar) cho thanh lịch */
  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: #f1f1f1; 
  }
  ::-webkit-scrollbar-thumb {
    background: #c1c1c1; 
    border-radius: 4px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #a8a8a8; 
  }
</style>