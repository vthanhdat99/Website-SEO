---
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"
import ZaloCTA from "../components/ZaloCTA.astro"
import SEO from "../components/SEO.astro"
// QUAN TRỌNG: Phải import file CSS này để Tailwind hoạt động
import "../styles/global.css"

const { title, description } = Astro.props
---

<html lang="vi" class="scroll-smooth">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <SEO title={title} description={description} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet">
  </head>

  <body class="font-['Inter',sans-serif] bg-gray-50 text-gray-950 antialiased min-h-screen flex flex-col">
    
    <Header />

    <main class="flex-grow">
      <slot />
    </main>

    <Footer />
    
    <div class="fixed bottom-6 right-6 z-40">
      <ZaloCTA />
    </div>

  </body>
</html>